---
import BaseHead from '../../components/BaseHead.astro';

const pageTitle = 'めもる。 | 思いついたら、すぐ書ける。';
const pageDescription =
	'ログインなしですぐ使えて、必要になったら同期もできる、やさしいメモアプリ「めもる。」の紹介ページです。';

const features = [
	{
		icon: 'edit_note',
		title: 'すぐ書ける',
		text: 'ログイン不要でそのまま使える。思いつきを逃さずメモできます。',
	},
	{
		icon: 'folder_open',
		title: '整理しやすい',
		text: 'フォルダとタグでしっかり分類。検索や並び替えも簡単です。',
	},
	{
		icon: 'restore_from_trash',
		title: '消しても戻せる',
		text: 'ゴミ箱で30日間保持。うっかり削除も安心です。',
	},
	{
		icon: 'cloud_sync',
		title: '必要になったら同期',
		text: 'Google ログインでクラウド同期。複数端末でも同じメモを使えます。',
	},
];

const details = [
	{
		title: 'ログインしなくても使える',
		body: '起動したらそのままメモ。会員登録や初期設定に時間を使わず、思いついたことをすぐ書き始められます。',
	},
	{
		title: 'フォルダとタグで整理しやすい',
		body: '仕事、買い物、アイデア、旅行の下書き。あとから見返しやすいように、自然な形で整理できます。',
	},
	{
		title: '消しても戻せる',
		body: '削除したメモはすぐに消えず、ゴミ箱で一定期間保管。消し間違いが気になる人でも使いやすい設計です。',
	},
	{
		title: '必要になったら同期できる',
		body: '普段はローカル保存で軽く使い、必要になったら Google ログインでクラウド同期へ。使い方に合わせて選べます。',
	},
];
---

<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,400..700,0..1,0"
		/>
		<style>
			:root {
				--memoru-orange: #ef6b1b;
				--memoru-orange-deep: #cc5512;
				--memoru-orange-soft: #fff0e5;
				--memoru-orange-line: rgba(239, 107, 27, 0.18);
				--memoru-ink: #23140d;
				--memoru-muted: #6b5850;
				--memoru-panel: rgba(255, 255, 255, 0.86);
				--memoru-shadow: 0 28px 70px rgba(100, 47, 19, 0.13);
			}

			body {
				background:
					radial-gradient(circle at top left, rgba(255, 224, 203, 0.9), transparent 23%),
					radial-gradient(circle at 85% 15%, rgba(255, 232, 214, 0.9), transparent 18%),
					radial-gradient(circle at bottom right, rgba(255, 238, 225, 0.85), transparent 24%),
					linear-gradient(180deg, #fffaf7 0%, #fff6f0 100%);
				color: var(--memoru-ink);
			}

			.memoru-page {
				overflow: hidden;
			}

			.memoru-page main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}

			.wrap {
				width: min(1320px, calc(100% - 40px));
				margin: 0 auto;
			}

			.hero {
				padding: 42px 0 28px;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
				gap: 28px;
				align-items: center;
			}

			.brand {
				display: inline-flex;
				align-items: center;
				gap: 18px;
				margin-bottom: 28px;
			}

			.brand-badge {
				width: 86px;
				height: 86px;
				border-radius: 28px;
				display: grid;
				place-items: center;
				background: linear-gradient(180deg, #fff2e8, #ffe9d6);
				box-shadow: 0 10px 30px rgba(239, 107, 27, 0.14);
				font-size: 2.2rem;
				color: var(--memoru-orange);
			}

			.material-symbols-rounded {
				font-family: 'Material Symbols Rounded';
				font-weight: normal;
				font-style: normal;
				font-size: 24px;
				line-height: 1;
				letter-spacing: normal;
				text-transform: none;
				display: inline-block;
				white-space: nowrap;
				word-wrap: normal;
				direction: ltr;
				font-feature-settings: 'liga';
				-webkit-font-smoothing: antialiased;
				font-variation-settings:
					'FILL' 0,
					'wght' 500,
					'GRAD' 0,
					'opsz' 24;
			}

			.icon-inline {
				display: inline-flex;
				align-items: center;
				justify-content: center;
			}

			.brand-badge .material-symbols-rounded {
				font-size: 2rem;
				font-variation-settings:
					'FILL' 1,
					'wght' 500,
					'GRAD' 0,
					'opsz' 48;
			}

			.brand-name {
				font-size: clamp(2rem, 4vw, 2.5rem);
				font-weight: 700;
				color: var(--memoru-orange);
			}

			.hero-copy h1 {
				font-size: clamp(3rem, 7vw, 4rem);
				line-height: 1.06;
				letter-spacing: -0.03em;
				margin-bottom: 1.1rem;
			}

			.hero-copy p {
				max-width: 34rem;
				font-size: clamp(1.1rem, 2.2vw, 1.55rem);
				color: var(--memoru-muted);
				margin-bottom: 1.6rem;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 14px;
				margin-bottom: 1rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.55rem;
				padding: 0.95rem 1.4rem;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
				border: 1px solid transparent;
				transition: transform 180ms ease, box-shadow 180ms ease;
			}

			.button .material-symbols-rounded {
				font-size: 1.25rem;
				font-variation-settings:
					'FILL' 1,
					'wght' 500,
					'GRAD' 0,
					'opsz' 24;
			}

			.button:hover {
				transform: translateY(-1px);
			}

			.button-primary {
				background: linear-gradient(180deg, #ff842e, var(--memoru-orange));
				color: #fff;
				box-shadow: 0 14px 28px rgba(239, 107, 27, 0.24);
			}

			.button-secondary {
				background: rgba(255, 255, 255, 0.7);
				border-color: var(--memoru-orange-line);
				color: var(--memoru-orange);
			}

			.hero-link {
				color: var(--memoru-orange);
				font-weight: 700;
				text-decoration: none;
			}

			.hero-visual {
				position: relative;
				min-height: 760px;
			}

			.phone {
				position: absolute;
				background: var(--memoru-panel);
				border: 1px solid rgba(255, 255, 255, 0.9);
				border-radius: 42px;
				box-shadow: var(--memoru-shadow);
				backdrop-filter: blur(18px);
				padding: 18px;
				color: var(--memoru-ink);
			}

			.phone-main {
				width: min(100%, 390px);
				top: 20px;
				left: 44px;
				z-index: 3;
			}

			.phone-manage {
				width: min(100%, 330px);
				top: 58px;
				right: 44px;
				transform: rotate(4deg);
				z-index: 2;
			}

			.phone-menu {
				width: min(100%, 285px);
				bottom: 10px;
				right: 0;
				transform: rotate(9deg);
				z-index: 1;
			}

			.phone-top {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 10px;
				margin-bottom: 16px;
			}

			.mini-button,
			.fab {
				display: grid;
				place-items: center;
				background: #fff8f2;
				border: 1px solid var(--memoru-orange-line);
				color: var(--memoru-orange);
				box-shadow: 0 8px 16px rgba(160, 92, 39, 0.08);
			}

			.mini-button {
				width: 44px;
				height: 44px;
				border-radius: 14px;
				font-size: 1.1rem;
			}

			.mini-button .material-symbols-rounded,
			.fab .material-symbols-rounded {
				font-size: 1.35rem;
			}

			.phone-title {
				font-size: 1.1rem;
				font-weight: 800;
			}

			.phone-title.accent {
				color: var(--memoru-orange);
			}

			.search-row,
			.filter-row {
				display: flex;
				gap: 10px;
				margin-bottom: 14px;
			}

			.search-box {
				flex: 1;
				display: flex;
				align-items: center;
				gap: 0.45rem;
				border: 1px solid var(--memoru-orange-line);
				background: rgba(255, 255, 255, 0.76);
				border-radius: 16px;
				padding: 12px 14px;
				color: #9d7e71;
				font-size: 0.95rem;
			}

			.note-list,
			.folder-list,
			.menu-list {
				display: grid;
				gap: 10px;
			}

			.note-card,
			.folder-card,
			.menu-card {
				background: rgba(255, 255, 255, 0.82);
				border: 1px solid var(--memoru-orange-line);
				border-radius: 18px;
				padding: 14px 16px;
			}

			.note-card small,
			.folder-card small {
				display: block;
				color: #9a7c6d;
				margin-bottom: 0.35rem;
			}

			.note-card strong,
			.folder-card strong,
			.menu-card strong {
				display: block;
			}

			.note-card p,
			.folder-card p {
				margin: 0.3rem 0 0;
				color: var(--memoru-muted);
				font-size: 0.9rem;
			}

			.menu-card {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-weight: 700;
				background: #ffefe1;
			}

			.menu-card .material-symbols-rounded {
				font-size: 1.2rem;
			}

			.menu-card.active {
				background: #fff8f2;
				color: var(--memoru-orange);
				outline: 1px solid rgba(239, 107, 27, 0.45);
			}

			.phone-footer {
				display: flex;
				justify-content: space-between;
				padding-top: 14px;
				margin-top: 18px;
				border-top: 1px solid rgba(120, 88, 69, 0.14);
				color: #8c8d95;
				font-size: 0.82rem;
			}

			.phone-footer span.active {
				color: var(--memoru-orange);
				font-weight: 700;
			}

			.fab {
				width: 52px;
				height: 52px;
				border-radius: 50%;
				font-size: 1.8rem;
				position: absolute;
				right: 26px;
				bottom: 86px;
				background: linear-gradient(180deg, #ff8a35, var(--memoru-orange));
				color: #fff;
				border: none;
			}

			.feature-strip {
				padding: 16px 0 28px;
			}

			.feature-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 16px;
			}

			.feature {
				display: flex;
				gap: 16px;
				padding: 22px 18px;
				border-radius: 26px;
				background: rgba(255, 255, 255, 0.78);
				border: 1px solid rgba(255, 255, 255, 0.95);
				box-shadow: 0 16px 35px rgba(96, 51, 24, 0.08);
			}

			.feature-icon {
				flex: 0 0 56px;
				width: 56px;
				height: 56px;
				border-radius: 18px;
				display: grid;
				place-items: center;
				background: linear-gradient(180deg, #fff1e8, #ffe9d6);
				color: var(--memoru-orange);
				font-size: 1.65rem;
				font-weight: 700;
			}

			.feature-icon .material-symbols-rounded {
				font-size: 1.9rem;
				font-variation-settings:
					'FILL' 1,
					'wght' 500,
					'GRAD' 0,
					'opsz' 32;
			}

			.feature h2 {
				font-size: 1.2rem;
				margin-bottom: 0.2rem;
			}

			.feature p {
				font-size: 0.96rem;
				margin: 0;
				color: var(--memoru-muted);
			}

			.summary {
				text-align: center;
				padding: 18px 0 20px;
			}

			.summary p {
				font-size: clamp(1.2rem, 2.5vw, 1.7rem);
				color: var(--memoru-muted);
			}

			.detail-section {
				padding: 26px 0 40px;
			}

			.section-header {
				max-width: 700px;
				margin-bottom: 28px;
			}

			.eyebrow {
				display: inline-block;
				margin-bottom: 0.8rem;
				padding: 0.4rem 0.75rem;
				border-radius: 999px;
				background: var(--memoru-orange-soft);
				color: var(--memoru-orange);
				font-weight: 700;
				font-size: 0.9rem;
			}

			.section-header h2 {
				font-size: clamp(2rem, 4vw, 2.5rem);
				margin-bottom: 0.7rem;
			}

			.section-header p {
				color: var(--memoru-muted);
			}

			.detail-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 18px;
			}

			.detail-card {
				padding: 24px;
				border-radius: 28px;
				background: rgba(255, 255, 255, 0.83);
				border: 1px solid rgba(255, 255, 255, 0.95);
				box-shadow: 0 18px 35px rgba(96, 51, 24, 0.08);
			}

			.detail-card h3 {
				font-size: 1.35rem;
				margin-bottom: 0.55rem;
			}

			.detail-card p {
				margin: 0;
				color: var(--memoru-muted);
			}

			.cta-section {
				padding: 24px 0 72px;
			}

			.cta-card {
				padding: 34px;
				border-radius: 32px;
				background:
					radial-gradient(circle at top right, rgba(255, 224, 203, 0.82), transparent 26%),
					rgba(255, 255, 255, 0.9);
				border: 1px solid rgba(255, 255, 255, 0.95);
				box-shadow: 0 24px 55px rgba(96, 51, 24, 0.1);
				text-align: center;
			}

			.cta-card h2 {
				font-size: clamp(2rem, 4vw, 3rem);
				margin-bottom: 0.8rem;
			}

			.cta-card p {
				max-width: 750px;
				margin: 0 auto 1.4rem;
				font-size: clamp(0.8rem, 4vw, 1.2rem);
				white-space: pre-line;
				color: var(--memoru-muted);
			}

			.cta-links {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 14px;
				margin-bottom: 1rem;
			}

			.sub-link {
				color: var(--memoru-orange);
				font-weight: 700;
				text-decoration: none;
			}

			@media (max-width: 1100px) {
				.hero-grid {
					grid-template-columns: 1fr;
				}

				.hero-visual {
					min-height: 620px;
				}

				.phone-main {
					left: 0;
				}
			}

			@media (max-width: 900px) {
				.feature-grid,
				.detail-grid {
					grid-template-columns: 1fr 1fr;
				}
			}

			@media (max-width: 720px) {
				.wrap {
					width: auto;
					margin-inline: clamp(28px, 8vw, 44px);
				}

				.hero {
					padding-top: 24px;
				}

				.hero-copy h1 {
					font-size: 2.8rem;
				}

				.hero-visual {
					min-height: auto;
					display: grid;
					gap: 16px;
				}

				.phone {
					position: static;
					width: auto;
					transform: none;
				}

				.phone-main,
				.phone-manage,
				.phone-menu {
					width: auto;
				}

				.feature-grid,
				.detail-grid {
					grid-template-columns: 1fr;
				}

				.cta-card,
				.detail-card,
				.feature {
					padding: 22px;
				}
			}
		</style>
	</head>
	<body>
		<div class="memoru-page">
			<main>
				<section class="hero">
					<div class="wrap hero-grid">
						<div class="hero-copy">
							<div class="brand">
								<div class="brand-badge">
									<span class="material-symbols-rounded" aria-hidden="true">edit_note</span>
								</div>
								<div class="brand-name">めもる。</div>
							</div>
							<h1>思いついたら、<br />すぐ書ける。</h1>
							<p>
								ログインなしですぐ使えて、必要になったら同期もできる、やさしいメモアプリ。
							</p>
							<div class="hero-actions">
								<a class="button button-primary" href="#android">
									<span class="material-symbols-rounded" aria-hidden="true">download</span>
									Android版を見る
								</a>
								<a class="button button-secondary" href="#web">
									<span class="material-symbols-rounded" aria-hidden="true">language</span>
									Web版について
								</a>
							</div>
							<a class="hero-link" href="#details">使い方を見る →</a>
						</div>

						<div class="hero-visual" aria-hidden="true">
							<div class="phone phone-main">
								<div class="phone-top">
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">menu</span>
									</div>
									<div class="phone-title accent">めもる。</div>
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">add</span>
									</div>
								</div>
								<div class="search-row">
									<div class="search-box">
										<span class="material-symbols-rounded" aria-hidden="true">search</span>
										<span>メモを検索</span>
									</div>
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">filter_list</span>
									</div>
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">swap_vert</span>
									</div>
								</div>
								<div class="note-list">
									<div class="note-card">
										<small>未分類</small>
										<strong>メモアプリをリリース</strong>
										<p>アイデア / メモ</p>
									</div>
									<div class="note-card">
										<small>仕事</small>
										<strong>会議メモ</strong>
										<p>打ち合わせ内容の整理とタスク確認</p>
									</div>
									<div class="note-card">
										<small>買い物</small>
										<strong>買い物リスト</strong>
										<p>牛乳・たまご・パン・コーヒー</p>
									</div>
								</div>
								<div class="fab">
									<span class="material-symbols-rounded" aria-hidden="true">add</span>
								</div>
								<div class="phone-footer">
									<span class="active">ホーム</span>
									<span>フォルダ</span>
									<span>ゴミ箱</span>
									<span>設定</span>
								</div>
							</div>

							<div class="phone phone-manage">
								<div class="phone-top">
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">menu</span>
									</div>
									<div class="phone-title">管理</div>
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">add</span>
									</div>
								</div>
								<div class="folder-list">
									<div class="folder-card">
										<small>フォルダ</small>
										<strong>未分類</strong>
										<p>2個のメモ</p>
									</div>
									<div class="folder-card">
										<small>タグ</small>
										<strong>#アイデア</strong>
										<p>2個のメモ</p>
									</div>
									<div class="folder-card">
										<small>タグ</small>
										<strong>#旅行</strong>
										<p>1個のメモ</p>
									</div>
								</div>
								<div class="phone-footer">
									<span>ホーム</span>
									<span class="active">フォルダ</span>
									<span>ゴミ箱</span>
									<span>設定</span>
								</div>
							</div>

							<div class="phone phone-menu">
								<div class="phone-top">
									<div class="phone-title">めもる。</div>
									<div class="mini-button">
										<span class="material-symbols-rounded" aria-hidden="true">close</span>
									</div>
								</div>
								<div class="menu-list">
									<div class="menu-card">
										<span class="material-symbols-rounded" aria-hidden="true">home</span>
										ホーム
									</div>
									<div class="menu-card active">
										<span class="material-symbols-rounded" aria-hidden="true">folder_open</span>
										フォルダ・タグ管理
									</div>
									<div class="menu-card">
										<span class="material-symbols-rounded" aria-hidden="true">delete</span>
										ゴミ箱
									</div>
									<div class="menu-card">
										<span class="material-symbols-rounded" aria-hidden="true">settings</span>
										設定
									</div>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="feature-strip">
					<div class="wrap feature-grid">
						{
							features.map((feature) => (
								<article class="feature">
									<div class="feature-icon">
										<span class="material-symbols-rounded" aria-hidden="true">{feature.icon}</span>
									</div>
									<div>
										<h2>{feature.title}</h2>
										<p>{feature.text}</p>
									</div>
								</article>
							))
						}
					</div>
				</section>

				<section class="summary">
					<div class="wrap">
						<p>めもる。は、あなたの毎日に寄り添う、シンプルでやさしいメモアプリです。</p>
					</div>
				</section>

				<section class="detail-section" id="details">
					<div class="wrap">
						<div class="section-header">
							<span class="eyebrow">Why Memoru</span>
							<h2>シンプルなのに、ちゃんと使える。</h2>
							<p>
								まずは軽く書けること。あとから整理できること。消しても戻せること。必要になったら同期できること。日常のメモに欲しいことを、無理のない形でまとめています。
							</p>
						</div>
						<div class="detail-grid">
							{
								details.map((detail) => (
									<article class="detail-card">
										<h3>{detail.title}</h3>
										<p>{detail.body}</p>
									</article>
								))
							}
						</div>
					</div>
				</section>

				<section class="cta-section">
					<div class="wrap">
						<div class="cta-card">
							<h2>毎日のメモに、ちょうどいいバランス。</h2>
							<p id="android">普段はローカル保存で軽く使い、必要に応じて Google ログインでクラウド同期。
											バックアップや同期を意識しすぎず、使いたい時にだけ使えるメモアプリです。
							</p>
							<div class="cta-links">
								<a class="button button-primary" href="#android">Android版を見る</a>
								<a class="button button-secondary" href="#web">Web版について</a>
							</div>
							<p id="web">
								<a class="sub-link" href="/memoru/privacy-policy">プライバシーポリシーを見る</a>
							</p>
						</div>
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
